# =============================================================================
# PG-Loop LCA/TEA Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# LLM Configuration (OpenAI-compatible interface)
# -----------------------------------------------------------------------------
# Base URL for OpenAI-compatible API (use proxy for Gemini)
# Default: https://api.openai.com/v1 (OpenAI direct)
# Gemini Proxy: http://127.0.0.1:8045/v1
LLM_BASE_URL=http://127.0.0.1:8045/v1

# API Key for the LLM service
LLM_API_KEY=sk-57cd6af0bb20448bbf0a37c6c400580c

# Model name (depends on your provider)
# OpenAI: gpt-4o, gpt-4o-mini
# Gemini via proxy: gemini-3-flash, gemini-2.0-flash
LLM_MODEL=gemini-3-flash

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
# Embedding model to use
# Options: bge-m3 (local, free), text-embedding-004 (Gemini API)
EMBEDDING_MODEL=bge-m3
#EMBEDDING_MODEL=text-embedding-004

# For API-based embeddings (optional, only if using text-embedding-004)
#GEMINI_API_KEY=your-gemini-api-key

# -----------------------------------------------------------------------------
# Legacy Configuration (kept for backward compatibility)
# -----------------------------------------------------------------------------
# These are still supported but LLM_* variables take precedence
# GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
