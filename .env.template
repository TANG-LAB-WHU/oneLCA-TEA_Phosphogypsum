# =============================================================================
# PG-Loop LCA/TEA Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# LLM Configuration — Ollama OpenAI-compatible /v1 endpoint
# -----------------------------------------------------------------------------
# Base URL for chat completions and embeddings (same Ollama server)
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=ollama
# Chat model — must match `ollama list` output
LLM_MODEL=qwen3.5:35b

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
# Embedding model — must match `ollama list` output
EMBEDDING_MODEL=bge-m3:567m
# Vector dimension output by the embedding model (bge-m3 = 1024)
EMBEDDING_DIM=1024

# -----------------------------------------------------------------------------
# Optional LLM request tuning (applies in this repo's Python clients)
# -----------------------------------------------------------------------------
# Prefer 32768 for LightRAG extraction stability on long prompts.
# This is passed to Ollama's OpenAI-compatible endpoint via extra_body options.
LLM_CONTEXT_LENGTH=32768
# Prefer strict JSON mode for structured extraction (auto-fallback if unsupported).
LLM_JSON_MODE=1

# -----------------------------------------------------------------------------
# Ollama server runtime tuning (set in system/user env, then restart Ollama)
# -----------------------------------------------------------------------------
# IMPORTANT:
# - Ollama runs as a separate process. These settings are most reliable when set
#   in OS-level environment variables (PowerShell `setx`), not only in `.env`.
# - After changing them, fully quit Ollama (tray icon -> Quit) and start again.
#
# Recommended for Windows + local 35B + embedding stability:
#   OLLAMA_FLASH_ATTENTION=0
#   OLLAMA_CONTEXT_LENGTH=32768
#   OLLAMA_NUM_PARALLEL=1
#   OLLAMA_MAX_LOADED_MODELS=1
#
# PowerShell example:
#   setx OLLAMA_FLASH_ATTENTION 0
#   setx OLLAMA_CONTEXT_LENGTH 32768
#   setx OLLAMA_NUM_PARALLEL 1
#   setx OLLAMA_MAX_LOADED_MODELS 1

# -----------------------------------------------------------------------------
# Optional RAGAnything / MinerU runtime knobs
# -----------------------------------------------------------------------------
# If MinerU auto mode is unstable in your environment, set explicit backend/device:
# RAGANYTHING_MINERU_BACKEND=pipeline
# RAGANYTHING_MINERU_DEVICE=cpu
# MinerU model source (default: Hugging Face official)
MINERU_MODEL_SOURCE=huggingface
HF_ENDPOINT=https://huggingface.co
# Optional token if your Hugging Face access requires authentication:
# HF_TOKEN=your_token_here
# If Hugging Face is blocked/slow in your network, fallback:
# MINERU_MODEL_SOURCE=modelscope
